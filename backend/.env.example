# Copy this file to .env and fill values before running.
# Never commit your real .env to git.

# API Keys (required)
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/auto

# CORS Origins - comma-separated, no spaces
# Development: http://localhost:5173
# Production (Vercel): https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173

# Max upload size in bytes (50 MB)
MAX_UPLOAD_SIZE=52428800

# Optional: set if Poppler is installed for PDF OCR support (Windows only)
# For production on Linux, Poppler is installed via apt-get
POPPLER_PATH=

# Environment
ENVIRONMENT=development
